<script>
  async function startCheckout() {
    try {
      const res = await fetch("https://whatcable.uk/api/checkout", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
      });
      const { url } = await res.json();
      if (url) window.location.href = url;
    } catch (e) {
      alert("Something went wrong. Please try again.");
    }
  }

  document.getElementById("buy-hero").addEventListener("click", startCheckout);
  document.getElementById("buy-pricing").addEventListener("click", startCheckout);
  document.getElementById("buy-cta").addEventListener("click", startCheckout);
</script>
{% endraw %}
